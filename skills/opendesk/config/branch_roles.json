{
  "roles": {
    "frontend": {
      "label": "Desktop — React · UI · Tauri · Rust",
      "description": "桌面端一体开发：前端展示 + Tauri IPC + Rust crates。UI 改动常伴随 src-tauri 配置。",
      "branch_prefix": "frontend",
      "allowed_globs": [
        "apps/desktop/**",
        "packages/ui/**",
        "packages/platform/**",
        "packages/contracts/**",
        "crates/**",
        "plan/**"
      ],
      "optional_globs": [
        "contracts/**"
      ],
      "forbidden_globs": [
        "python/**"
      ],
      "rule_files": ["frontend.md", "rust.md"]
    },
    "python": {
      "label": "Python AI Runtime",
      "description": "Sidecar 与 python/packages；禁止改 React/Rust 业务层。",
      "branch_prefix": "python",
      "allowed_globs": [
        "python/**",
        "plan/**"
      ],
      "optional_globs": [
        "contracts/**"
      ],
      "forbidden_globs": [
        "apps/desktop/**",
        "packages/ui/**",
        "packages/platform/**",
        "crates/**"
      ],
      "rule_files": ["python.md"]
    },
    "contract": {
      "label": "Contracts — 跨端契约",
      "description": "仅改 contracts/ 与 codegen 脚本；变更后需同步三端生成物。",
      "branch_prefix": "contract",
      "allowed_globs": [
        "contracts/**",
        "skills/opendesk/scripts/sync_contracts.py",
        "plan/**"
      ],
      "optional_globs": [],
      "forbidden_globs": [
        "apps/**",
        "crates/**",
        "python/**",
        "packages/**"
      ],
      "rule_files": []
    },
    "integration": {
      "label": "Integration — main",
      "description": "集成分支；合并前需全量 lint，跨层改动需评审。",
      "branch_prefix": "main",
      "allowed_globs": ["**/*"],
      "optional_globs": [],
      "forbidden_globs": [],
      "rule_files": ["frontend.md", "rust.md", "python.md"]
    }
  },
  "legacy_branch_map": {
    "role/frontend": "frontend",
    "role/python": "python"
  }
}
