{
  "name": "opendesk",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @desk/desktop dev",
    "build": "pnpm --filter @desk/desktop build",
    "build:sidecar": "node tooling/scripts/build-sidecar.mjs",
    "build:license-verifier": "node tooling/scripts/build-license-verifier.mjs",
    "activation-gen:gui": "node tooling/scripts/run-activation-gen-gui.mjs",
    "preview": "pnpm --filter @desk/desktop preview",
    "tauri": "node tooling/scripts/tauri.mjs",
    "tauri:build:locked": "node tooling/scripts/tauri-build-locked.mjs",
    "tauri:dev:locked": "node tooling/scripts/tauri-dev-locked.mjs",
    "prepare": "husky",
    "lint": "pnpm lint:frontend && pnpm lint:rust && pnpm lint:python",
    "lint:fix": "pnpm lint:frontend:fix && pnpm lint:rust:fix && pnpm lint:python:fix",
    "lint:frontend": "eslint . && pnpm lint:types",
    "lint:frontend:fix": "eslint . --fix",
    "lint:types": "tsc -p tsconfig.lint.json --noEmit",
    "lint:rust": "node tooling/scripts/lint-rust.mjs",
    "lint:rust:fix": "node tooling/scripts/lint-rust-fix.mjs",
    "lint:python": "node tooling/scripts/lint-python.mjs",
    "lint:python:fix": "node tooling/scripts/lint-python-fix.mjs",
    "branch": "python skills/opendesk/scripts/create_branch.py --interactive",
    "branch:create": "python skills/opendesk/scripts/create_branch.py",
    "branch:sync": "python skills/opendesk/scripts/sync_branch_rules.py"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.48.0"
  }
}
