{
  "name": "opendesk",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @desk/desktop dev",
    "build": "pnpm --filter @desk/desktop build",
    "preview": "pnpm --filter @desk/desktop preview",
    "tauri": "pnpm --filter @desk/desktop tauri",
    "lint": "pnpm lint:frontend && pnpm lint:rust && pnpm lint:python",
    "lint:fix": "pnpm lint:frontend:fix && pnpm lint:rust:fix && pnpm lint:python:fix",
    "lint:frontend": "eslint .",
    "lint:frontend:fix": "eslint . --fix",
    "lint:rust": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets -- -D warnings",
    "lint:rust:fix": "cargo fmt --all",
    "lint:python": "node tooling/scripts/lint-python.mjs",
    "lint:python:fix": "node tooling/scripts/lint-python-fix.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.48.0"
  }
}
