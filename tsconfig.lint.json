{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@desk/ui": ["packages/ui/src"],
      "@desk/ui/*": ["packages/ui/src/*"],
      "@desk/platform": ["packages/platform/src"],
      "@desk/platform/*": ["packages/platform/src/*"],
      "@desk/contracts": ["packages/contracts/src"],
      "@desk/contracts/*": ["packages/contracts/src/*"],
      "@feature/*": ["apps/desktop/src/features/*"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx"
  ],
  "exclude": [
    "**/dist/**",
    "**/node_modules/**",
    "**/target/**",
    "apps/desktop/vite.config.ts"
  ]
}
