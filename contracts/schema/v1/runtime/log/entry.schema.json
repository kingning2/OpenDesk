{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "opendesk://runtime/log/entry/v1",
  "title": "runtime/log/entry",
  "description": "One JSON Lines log entry emitted by the Python sidecar to stdout.",
  "type": "object",
  "required": ["schema_version", "timestamp", "level", "source", "logger", "message"],
  "properties": {
    "schema_version": {"const": "1"},
    "timestamp": {"type": "string", "format": "date-time"},
    "level": {
      "type": "string",
      "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]
    },
    "source": {"const": "python"},
    "logger": {"type": "string", "minLength": 1},
    "message": {"type": "string", "maxLength": 4096},
    "event": {"type": "string"},
    "feature": {"type": "string"},
    "trace_id": {"type": "string"},
    "task_id": {"type": "string"},
    "tenant_id": {"type": "string"},
    "attributes": {"type": "object", "additionalProperties": true},
    "exception": {
      "type": "object",
      "required": ["type", "message", "stack"],
      "properties": {
        "type": {"type": "string"},
        "message": {"type": "string"},
        "stack": {"type": "string", "maxLength": 8000}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
