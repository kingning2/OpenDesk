{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "opendesk://crawler/event/job.progress/v1",
  "title": "crawler/job.progress",
  "description": "Crawl job progress snapshot pushed to UI (replaces status polling).",
  "type": "object",
  "required": ["event_id", "occurred_at", "job_id", "platform", "scanned_count", "accepted_count"],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "occurred_at": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "platform": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "description": "queued | running | completed | failed | cancelled"
    },
    "message": {
      "type": "string",
      "description": "Localized progress message for UI."
    },
    "stop_reason": {
      "type": "string"
    },
    "current_keyword": {
      "type": "string"
    },
    "scanned_count": {
      "type": "integer"
    },
    "accepted_count": {
      "type": "integer"
    },
    "quota_used": {
      "type": "integer"
    },
    "search_pages": {
      "type": "integer"
    },
    "keyword_scanned": {
      "type": "integer",
      "description": "Channels scanned for current_keyword so far."
    },
    "keyword_accepted": {
      "type": "integer",
      "description": "Channels accepted for current_keyword so far."
    },
    "keywords_total": {
      "type": "integer"
    },
    "keywords_done": {
      "type": "integer"
    },
    "keyword_stats_json": {
      "type": "string",
      "description": "JSON array of {keyword, scanned, accepted}."
    },
    "error_message": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
